local M = {}

local config = {
  api_key = nil,
  model = "gpt-4o-mini",
  max_tokens = 150,
  temperature = 0.3,
  base_url = "https://api.openai.com/v1",
}

local function get_config_path()
  return vim.fn.stdpath("config") .. "/openai_config.json"
end

function M.setup(opts)
  opts = opts or {}
  for k, v in pairs(opts) do
    config[k] = v
  end
  
  -- Load API key from config file
  local config_path = get_config_path()
  local ok, data = pcall(vim.fn.readfile, config_path)
  if ok and data and #data > 0 then
    local json_ok, json_data = pcall(vim.fn.json_decode, table.concat(data, "\n"))
    if json_ok and json_data and json_data.api_key then
      config.api_key = json_data.api_key
    end
  end
end

function M.has_api_key()
  return config.api_key ~= nil and config.api_key ~= ""
end

function M.set_api_key(key)
  if not key or key == "" then
    return false, "API key cannot be empty"
  end
  
  -- Test the API key
  local test_ok, test_err = M.test_api_key(key)
  if not test_ok then
    return false, "Invalid API key: " .. test_err
  end
  
  -- Save the key
  config.api_key = key
  
  -- Persist to config file
  local config_data = {
    api_key = key,
    model = config.model,
    base_url = config.base_url
  }
  
  local config_path = get_config_path()
  local json_str = vim.fn.json_encode(config_data)
  vim.fn.writefile({json_str}, config_path)
  
  return true, "API key saved successfully"
end

function M.test_api_key(api_key)
  local test_api_key = api_key or config.api_key
  if not test_api_key then
    return false, "No API key provided"
  end
  
  -- Make a simple test request to check API key validity
  local response = vim.system({
    "curl",
    "-s",
    "-X", "POST",
    "-H", "Content-Type: application/json",
    "-H", "Authorization: Bearer " .. test_api_key,
    config.base_url .. "/chat/completions",
    "-d", vim.fn.json_encode({
      model = "gpt-3.5-turbo",
      messages = {{role = "user", content = "Hello"}},
      max_tokens = 5
    })
  }, { text = true }):wait()
  
  if response.code ~= 0 then
    return false, "Network error: " .. (response.stderr or "unknown error")
  end
  
  local json_ok, json_data = pcall(vim.fn.json_decode, response.stdout or "")
  if not json_ok then
    return false, "Invalid API response"
  end
  
  if json_data.error then
    return false, json_data.error.message or "API error"
  end
  
  return true
end

function M.generate_commit_message(prompt, callback)
  if not M.has_api_key() then
    callback(nil, "No OpenAI API key configured. Please set one with :OpenAISetKey")
    return false
  end
  
  -- Schedule the entire API call in main event loop
  vim.schedule(function()
    local messages = {
      {
        role = "system",
        content = "You are a helpful assistant that generates concise git commit messages."
      },
      {
        role = "user",
        content = prompt
      }
    }
    
    local request_data = {
      model = config.model,
      messages = messages,
      max_tokens = config.max_tokens,
      temperature = config.temperature
    }
    
    -- Now we're in main event loop, safe to call vim.fn.*
    local json_data = vim.fn.json_encode(request_data)
    local temp_file = vim.fn.tempname()
    vim.fn.writefile({json_data}, temp_file)
    
    vim.system({
      "curl",
      "-s",
      "-X", "POST",
      "-H", "Content-Type: application/json",
      "-H", "Authorization: Bearer " .. config.api_key,
      config.base_url .. "/chat/completions",
      "-d", "@" .. temp_file
    }, { text = true }, function(result)
      vim.schedule(function()
        vim.fn.delete(temp_file)
        if result.code ~= 0 then
          callback(nil, "API request failed: " .. (result.stderr or "unknown error"))
          return
        end
        
        local json_ok, json_response = pcall(vim.fn.json_decode, result.stdout or "")
        if not json_ok then
          callback(nil, "Failed to parse API response")
          return
        end
        
        if json_response.error then
          callback(nil, json_response.error.message or "API error")
          return
        end
        
        if not json_response.choices or #json_response.choices == 0 then
          callback(nil, "No response from API")
          return
        end
        
        local message = json_response.choices[1].message.content
        callback(message, nil)
      end)
    end)
  end)
  
  return true
end

-- Create commands
function M.create_commands()
  vim.api.nvim_create_user_command("OpenAISetKey", function(opts)
    local key = opts.args
    if not key or key == "" then
      vim.notify("Usage: OpenAISetKey <api-key>", vim.log.levels.ERROR)
      return
    end
    
    local ok, err = M.set_api_key(key)
    if ok then
      vim.notify("OpenAI API key saved and validated", vim.log.levels.INFO)
    else
      vim.notify("Failed to save API key: " .. err, vim.log.levels.ERROR)
    end
  end, { nargs = 1 })
end

return M