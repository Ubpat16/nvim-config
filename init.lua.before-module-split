--- Walk upward from `start_dir` and return the first usable venv interpreter, or nil.
---@param start_dir string
---@return string|nil
local function lc_find_venv_python(start_dir)
  if start_dir == nil or start_dir == "" then
    start_dir = vim.fn.getcwd()
  end
  local cur = vim.fs.normalize(vim.fn.fnamemodify(start_dir, ":p"))
  local rels = {
    ".venv/bin/python3",
    ".venv/bin/python",
    "venv/bin/python3",
    "venv/bin/python",
    "env/bin/python3",
    "env/bin/python",
  }
  for _ = 1, 48 do
    for _, rel in ipairs(rels) do
      local cand = vim.fs.joinpath(cur, rel)
      if vim.fn.executable(cand) == 1 then
        return vim.fs.normalize(cand)
      end
    end
    local parent = vim.fn.fnamemodify(cur, ":h")
    if parent == cur then
      break
    end
    cur = parent
  end
  return nil
end

--- If a project venv exists, set VIRTUAL_ENV, refresh Pyright, and re-run dap-python setup.
---@param bufnr integer
local function lc_apply_python_venv(bufnr)
  if not vim.api.nvim_buf_is_valid(bufnr) then
    return
  end
  local ft = vim.bo[bufnr].filetype
  local name = vim.api.nvim_buf_get_name(bufnr)
  if ft ~= "python" and not (name ~= "" and name:lower():match("%.py$")) then
    return
  end
  local path = vim.api.nvim_buf_get_name(bufnr)
  local start = (path and path ~= "") and vim.fn.fnamemodify(path, ":p:h") or vim.fn.getcwd()
  local py = lc_find_venv_python(start)
  if not py then
    local root = vim.fs.root(bufnr, { ".git", "pyproject.toml", "manage.py", "setup.py", "Pipfile" })
    if root then
      py = lc_find_venv_python(root)
    end
  end
  if not py then
    return
  end
  local venv_root = vim.fn.fnamemodify(py, ":h:h")
  vim.env.VIRTUAL_ENV = venv_root

  for _, client in ipairs(vim.lsp.get_clients({ bufnr = bufnr })) do
    if client.name == "pyright" then
      client.settings = client.settings or {}
      client.settings.python = vim.tbl_deep_extend("force", client.settings.python or {}, { pythonPath = py })
      client:notify("workspace/didChangeConfiguration", { settings = nil })
    end
  end
end

