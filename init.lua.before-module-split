local function lc_gitsigns_not_attached()
  vim.notify(
    "Gitsigns is not attached to this file. Open a file inside a Git repo, e.g. Backend, Web, or Mobile.",
    vim.log.levels.WARN
  )
end

vim.keymap.set("n", "<F9>", lc_gitsigns_not_attached, { desc = "Preview git hunk" })
